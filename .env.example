# VRIP Environment Configuration
# Use this file as a template for your .env file

# --- Core Platform ---
ENVIRONMENT=development
PROJECT_NAME="Vendor Risk Intelligence Platform"
LOG_LEVEL=INFO

# --- Infrastructure ---
POSTGRES_USER=vrip_admin
POSTGRES_PASSWORD=vrip_password_secure_123
POSTGRES_DB=vrip_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- AI & LLM (Groq) ---
GROQ_API_KEY=your_groq_api_key_here
DEFAULT_LLM_MODEL=llama-3.1-70b-versatile
EMBEDDING_MODEL=nomic-embed-text # Still need a local or API provider for embeddings

# --- MCP Services ---
MCP_GATEWAY_PORT=8000
MCP_POSTGRES_PORT=8001
MCP_QDRANT_PORT=8002
MCP_WEB_PORT=8003
MCP_FILES_PORT=8004
MCP_RISK_PORT=8005

# --- API & Frontend ---
API_PORT=8080
FRONTEND_PORT=3000

# --- Airflow ---
AIRFLOW_IMAGE_NAME=apache/airflow:2.9.1
_PIP_ADDITIONAL_DEPENDENCIES=psycopg2-binary qdrant-client groq pydantic-settings
